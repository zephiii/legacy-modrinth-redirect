{
  "name": "Legacy Modrinth Redirect",
  "description": "Ensure Modrinth always loads the April Fools 2026 (\"Legacy\") design",
  "version": "1.0.0",
  "manifest_version": 3,
  "browser_specific_settings": {
    "gecko_android": {},
    "gecko": {
      "id": "{9063c2e9-e07c-4c2c-9646-cfe7ca8d0498}",
      "strict_min_version": "130.0"
    }
  },
  "icons": {
    "16": "img/icon16.png",
    "32": "img/icon32.png",
    "48": "img/icon48.png",
    "64": "img/icon64.png",
    "96": "img/icon96.png",
    "128": "img/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://april-fools-2026.modrinth.com/*"],
      "css": ["styles.css"]
    }
  ],
  "permissions": ["declarativeNetRequestWithHostAccess"],
  "host_permissions": [
    "*://modrinth.com/*",
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  }
}
